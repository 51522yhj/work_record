{
  "name": "work-record-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "A local-first Electron floating desktop work record app.",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && set WORK_RECORD_DEV=1&& electron .\"",
    "build": "vite build",
    "dist": "npm.cmd run build && electron-builder --win nsis",
    "preview": "vite preview --host 127.0.0.1",
    "start": "electron ."
  },
  "build": {
    "appId": "com.local.workrecord",
    "productName": "Work Record",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Work Record"
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.4",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "lucide-react": "^0.545.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "vite": "^7.1.7",
    "wait-on": "^8.0.4"
  },
  "devDependencies": {
    "electron": "^38.2.2",
    "electron-builder": "^26.8.1"
  }
}
